{
  "name": "terminal-es",
  "displayName": "Error Sounds for Terminal",
  "description": "Plays a sound when a terminal command prints an error or exits with a non-zero code.",
  "version": "1.2.0",
  "publisher": "nlln19",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/nlln19/esft"
  },
  "license": "MIT",
  "keywords": [
    "terminal",
    "error",
    "sound",
    "alert",
    "notification",
    "powershell",
    "debugging"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "terminalErrorSound.testSound",
        "title": "Terminal Error Sound: Test Sound"
      },
      {
        "command": "terminalErrorSound.selectSound",
        "title": "Terminal Error Sound: Import Custom Sound"
      },
      {
        "command": "terminalErrorSound.chooseBuiltInSound",
        "title": "Terminal Error Sound: Choose Built-in Sound"
      },
      {
        "command": "terminalErrorSound.resetSound",
        "title": "Terminal Error Sound: Reset Custom Sound"
      },
      {
        "command": "terminalErrorSound.toggleEnabled",
        "title": "Terminal Error Sound: Toggle Enabled"
      },
      {
        "command": "terminalErrorSound.chooseTriggerMode",
        "title": "Terminal Error Sound: Choose Trigger Mode"
      }
    ],
    "configuration": {
      "title": "Terminal Error Sound",
      "properties": {
        "terminalErrorSound.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable terminal error sounds."
        },
        "terminalErrorSound.soundPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to a custom .wav sound file."
        },
        "terminalErrorSound.patterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "\\berror\\b",
            "\\bfailed\\b",
            "\\bfailure\\b",
            "\\bexception\\b",
            "traceback",
            "panic:",
            "fatal:",
            "segmentation fault",
            "abort trap",
            "command not found",
            "not recognized as",
            "not found",
            "no such file or directory",
            "permission denied",
            "access denied",
            "cannot find",
            "module not found",
            "syntaxerror",
            "typeerror",
            "referenceerror",
            "npm err!",
            "die benennung .* wurde nicht als name",
            "der befehl .* ist entweder falsch geschrieben"
          ],
          "description": "Regex patterns that trigger the sound when they appear in terminal output."
        },
        "terminalErrorSound.builtInSound": {
          "type": "string",
          "default": "fahh",
          "enum": [
            "fahh",
            "bruh",
            "fail",
            "ohmygod",
            "vineboom"
          ],
          "description": "Select one of the built-in error sounds."
        },
        "terminalErrorSound.triggerMode": {
          "type": "string",
          "default": "both",
          "enum": [
            "both",
            "exitCode",
            "patterns"
          ],
          "enumDescriptions": [
            "Play a sound when an error pattern is detected or when a command exits with a non-zero exit code.",
            "Play a sound only when a command exits with a non-zero exit code.",
            "Play a sound only when an error pattern is detected in the terminal output."
          ],
          "description": "Choose when the terminal error sound should be triggered."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  }
}